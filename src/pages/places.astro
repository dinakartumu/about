---
import Layout from '../layouts/Layout.astro';
import { rewindFetch, shapePlacesStats, shapeRecentCheckins } from '../lib/rewind';

type StatsJson = Parameters<typeof shapePlacesStats>[0];
type RecentJson = Parameters<typeof shapeRecentCheckins>[0];

// Any failure throws and fails the build — never publish a page with
// missing sections.
const [stats, checkins] = await Promise.all([
  rewindFetch<StatsJson>('/v1/places/stats').then(shapePlacesStats),
  rewindFetch<RecentJson>('/v1/places/recent?limit=30').then(shapeRecentCheckins),
]);

const n = (v: number) => Math.round(v).toLocaleString('en-US');
---
<Layout
  title="Places · Dinakar Tumu"
  description="Where Dinakar Tumu has been — recent check-ins with top categories and cities."
>
  <section class="container head">
    <h1>{n(stats.total)} Check-ins · {n(stats.uniqueVenues)} Venues · {n(stats.thisYear)} This Year</h1>
  </section>

  <section class="container">
    <h2>Recent Check-ins</h2>
    <ol class="list" role="list">
      {checkins.map((c) => (
        <li>
          <div class="row">
            <span class="meta">
              <span class="name">{c.venueName}</span>
              <span class="sub muted">{c.place ? `${c.category} · ${c.place}` : c.category}</span>
              {c.shout && <span class="shout sub">{c.shout}</span>}
            </span>
            <span class="date muted">{c.date}</span>
          </div>
        </li>
      ))}
      {checkins.length === 0 && <li class="empty muted">No check-ins yet.</li>}
    </ol>
  </section>

  <section class="container">
    <div class="cols">
      <div>
        <h2>Top Categories</h2>
        <ol class="list compact" role="list">
          {stats.topCategories.map((c) => (
            <li>
              <div class="row">
                <span class="name">{c.name}</span>
                <span class="count muted">{n(c.count)}</span>
              </div>
            </li>
          ))}
        </ol>
      </div>
      <div>
        <h2>Top Cities</h2>
        <ol class="list compact" role="list">
          {stats.topCities.map((c) => (
            <li>
              <div class="row">
                <span class="name">{c.name}</span>
                <span class="count muted">{n(c.count)}</span>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>
</Layout>

<style>
  .head h1 { margin-bottom: 0.5rem; }

  h2 { font-size: 1.1rem; margin: 2.25rem 0 0.75rem; }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 44rem;
  }
  .list li + li { border-top: 1px solid var(--surface); }
  .row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0;
  }
  .meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .name {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub { font-size: 0.85rem; }
  .shout { font-style: italic; }

  .date,
  .count {
    margin-left: auto;
    white-space: nowrap;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  .cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 2.5rem;
    max-width: 44rem;
  }
  .compact .name { font-weight: 400; color: var(--text); }
  @media (max-width: 540px) {
    .cols { grid-template-columns: 1fr; }
  }

  .empty { padding: 0.55rem 0; }
</style>
