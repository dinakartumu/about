---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { photoUrl } from '../lib/images';

const portrait = '/portrait.jpg';

// Pull real frames from the existing photosets to break up the prose,
// the way Paul's about page interleaves photography with writing.
const sets = await getCollection('photosets');
const bySlug = Object.fromEntries(sets.map((s) => [s.data.slug, s.data]));

const pick = (slug: string, wide = true) => {
  const set = bySlug[slug];
  if (!set) return null;
  const photo =
    (wide ? set.photos.find((p) => p.width > p.height) : set.photos.find((p) => p.height > p.width)) ??
    set.photos[0];
  return { photo, title: set.data?.title ?? set.title, slug };
};

// One wide banner after the intro, and a small trio for the photography section.
const banner = pick('goa') ?? pick('varanasi');
const trio = [pick('varanasi'), pick('stanford-university'), pick('mill-valley')].filter(Boolean) as {
  photo: { id: string; width: number; height: number };
  title: string;
  slug: string;
}[];

const work = [
  { role: 'Founding Engineer', org: 'Pageloop', where: 'Bengaluru', period: '2024 — Present' },
  { role: 'Frontend Developer', org: 'Liscio', where: 'Remote', period: '2017 — 2023' },
  { role: 'Front End Developer', org: 'Wooter', where: 'New York', period: '2015 — 2017' },
];

const education = [
  { degree: 'M.S., Computer Science', org: 'New York Institute of Technology', period: '2013 — 2015' },
  { degree: 'B.Tech, Information Technology', org: 'Hindustan University', period: '2008 — 2012' },
];
---
<Layout title="About · Dinakar Tumu">
  <article class="about">
    <header class="hero container">
      <div class="hero-text">
        <h1>Hi, I'm Dinakar.</h1>
      </div>
      <img class="portrait" src={portrait} alt="Dinakar Tumu" width="1400" height="1400" />
    </header>

    <div class="body container">
      <p>
        I build software for a living and take photographs for everything else. Right now
        I'm a founding engineer at <a href="https://pageloop.ai">Pageloop</a>, where we're
        building an AI agent for help-center operations. It reads what changed in your
        product — Linear issues, release notes, support tickets, Slack threads — and
        updates your Intercom and Zendesk articles in seconds, so support teams stop
        shipping outdated screenshots and stale FAQs.
      </p>
      <p>
        I've been writing code since 2012. I did my master's in Computer Science at NYIT
        in New York, and spent the better part of a decade shipping web, mobile, and desktop
        products across New York and the Bay Area — an Ionic app at Wooter, and six years of
        frontend at Liscio, where I also built a desktop app and its Stripe and QuickBooks
        integrations.
      </p>
    </div>

    {banner && (
      <figure class="band container">
        <img
          src={photoUrl(banner.photo.id, { width: 1600, fit: 'scale-down' })}
          width={banner.photo.width}
          height={banner.photo.height}
          alt=""
          loading="lazy"
          decoding="async"
        />
        <figcaption>{banner.title} · <a href={`/photos/${banner.slug}`}>see the set</a></figcaption>
      </figure>
    )}

    <section class="body container">
      <h2>What I'm working on</h2>
      <p>
        Right now I'm building <a href="https://nostaliga.app">Nostaliga</a>, an app that
        surfaces the memories tied to the music you listen to — the best ride, the most
        memorable trip, your favorite coffee shop, and everything in between — all
        reconstructed on your device.
      </p>
    </section>

    <section class="body container">
      <h2>Photography</h2>
      <p>
        I got into photography during my master's in New York. Every weekend a friend and
        I would pick a neighborhood — the West Village, DUMBO, wherever — and just walk it
        with our phones. It was the peak of iPhone photography, so we'd come home, edit
        everything in VSCO, and post it to the VSCO community.
      </p>
      <p>
        When I moved to the Bay Area I got into cycling, and during COVID I decamped to
        La Mesa in San Diego with friends, where wandering new neighborhoods on foot became
        the whole point again. Back in the Bay Area I kept up the long walks and the
        pictures, <a href="https://x.com/dinakartumu/status/1477819452141965313">posting
        them on Twitter</a> along the way.
      </p>
      <p>
        I'm a big fan of colors, so the editing is half the
        fun: everything here was edited in Lightroom, where I like experimenting with
        different presets until the mood feels right.
      </p>
    </section>

    {trio.length > 0 && (
      <div class="trio container">
        {trio.map(({ photo, slug }) => (
          <a href={`/photos/${slug}`}>
            <img
              src={photoUrl(photo.id, { width: 800, height: 600, fit: 'cover' })}
              width="800"
              height="600"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
    )}

    <div class="body container">
      <p><a class="more" href="/photos">Browse all the photosets →</a></p>
    </div>

    <section class="body container">
      <h2>Where I've worked</h2>
      <ul class="timeline">
        {work.map((w) => (
          <li>
            <div>
              <span class="role">{w.role}</span>
              <span class="org muted">{w.org} · {w.where}</span>
            </div>
            <span class="period muted">{w.period}</span>
          </li>
        ))}
      </ul>

      <h3 class="edu-head">Education</h3>
      <ul class="timeline">
        {education.map((e) => (
          <li>
            <div>
              <span class="role">{e.degree}</span>
              <span class="org muted">{e.org}</span>
            </div>
            <span class="period muted">{e.period}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="body container">
      <h2>Get in touch</h2>
      <p>
        I'm always happy to hear from people building thoughtful software — or just
        wanting to talk shop about cameras. Reach me at
        <a href="mailto:dinakar91@gmail.com">dinakar91@gmail.com</a>, or find me on
        <a href="https://github.com/dinakartumu">GitHub</a> and
        <a href="https://www.linkedin.com/in/dinakartumu">LinkedIn</a>.
      </p>
    </section>
  </article>
</Layout>

<style>
  /* Paul-Stamatiou-style long read: a narrow prose column with photos that
     break out wider. Reuses the site's .container for the outer bound. */
  .about a { color: var(--heading); text-decoration: underline; text-underline-offset: 3px; }
  .about a:hover { color: var(--accent); }

  .hero { max-width: 44rem; margin: 1rem auto 3rem; }
  .hero h1 { font-size: clamp(2.2rem, 5vw, 3.2rem); margin: 0; }
  .portrait {
    width: 100%;
    border-radius: 10px;
    background: var(--surface);
    margin-top: 2rem;
  }

  /* Prose blocks share one measure and sit inside the wide container. */
  .body { max-width: 44rem; }
  .body p { font-size: 1.05rem; margin: 0 0 1.25rem; }
  .body h2 { font-size: 1.35rem; margin: 2.75rem 0 1rem; }

  .band { margin: 3rem auto; }
  .band img { width: 100%; border-radius: 8px; background: var(--surface); }
  .band figcaption { margin-top: 0.6rem; font-size: 0.85rem; color: var(--muted); }
  .band figcaption a { color: var(--muted); }

  .trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 1.5rem auto 0.5rem;
  }
  .trio img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 6px;
    background: var(--surface);
  }
  .trio a:hover img { opacity: 0.85; }
  .more { font-size: 0.95rem; }

  .timeline { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.1rem; }
  .timeline li { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; }
  .timeline .role { color: var(--heading); font-weight: 500; display: block; }
  .timeline .org { display: block; font-size: 0.9rem; margin-top: 0.15rem; }
  .timeline .period { white-space: nowrap; font-size: 0.9rem; }
  .edu-head { font-size: 1rem; font-weight: 600; margin: 2.25rem 0 1.1rem; color: var(--muted); }

  @media (max-width: 46rem) {
    .trio { grid-template-columns: 1fr 1fr; }
    .trio a:last-child { display: none; }
  }
</style>
