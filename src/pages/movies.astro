---
import Layout from '../layouts/Layout.astro';
import { rewindFetch, shapeRecentWatches, shapeWatchingStats } from '../lib/rewind';

type StatsJson = Parameters<typeof shapeWatchingStats>[0];
type RecentJson = Parameters<typeof shapeRecentWatches>[0];

// Any failure throws and fails the build — never publish a page with
// missing sections.
const [stats, watches] = await Promise.all([
  rewindFetch<StatsJson>('/v1/watching/stats').then(shapeWatchingStats),
  rewindFetch<RecentJson>('/v1/watching/recent?limit=24').then(shapeRecentWatches),
]);

const n = (v: number) => Math.round(v).toLocaleString('en-US');
const linkAttrs = (link: string | null) =>
  link ? { href: link, target: '_blank', rel: 'noopener' } : {};
---
<Layout
  title="Movies · Dinakar Tumu"
  description="What Dinakar Tumu has been watching — recently watched films with ratings."
>
  <section class="container head">
    <h1>{n(stats.totalMovies)} Films · {n(stats.moviesThisYear)} This Year · {n(stats.totalHours)} Hours</h1>
  </section>

  <section class="container">
    <h2>Recently Watched</h2>
    <ol class="grid" role="list">
      {watches.map((m) => (
        <li>
          <a class="tile" {...linkAttrs(m.tmdbUrl)}>
            {m.image ? (
              <img
                class="poster"
                src={m.image.url}
                alt=""
                width="200"
                height="300"
                loading="lazy"
                decoding="async"
                style={`background:${m.image.dominantColor}`}
              />
            ) : (
              <span class="poster fallback">
                <span class="title">{m.title}</span>
                {m.year !== null && <span class="sub muted">{m.year}</span>}
              </span>
            )}
            {m.image && (
              <span class="title">
                {m.title}
                {m.year !== null && <span class="muted"> ({m.year})</span>}
              </span>
            )}
            {m.stars && m.rating != null && (
              <span class="stars" role="img" aria-label={`Rated ${m.rating} out of 5`}>{m.stars}</span>
            )}
            <span class="sub muted">{m.watchedDate}{m.rewatch && ' · Rewatch'}</span>
          </a>
        </li>
      ))}
      {watches.length === 0 && <li class="empty muted">Nothing watched yet.</li>}
    </ol>
  </section>
</Layout>

<style>
  .container { max-width: 44rem; }
  .head h1 { margin-bottom: 0.5rem; }

  h2 { font-size: 1.1rem; margin: 2.25rem 0 0.75rem; }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.5rem 1rem;
  }

  .tile { display: flex; flex-direction: column; }
  a.tile[href]:hover .title { color: var(--accent); }

  .poster {
    width: 100%;
    aspect-ratio: 2 / 3;
    height: auto;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 0.4rem;
  }

  /* Title card shown while a poster is still processing (image null). */
  .fallback {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem;
    text-align: center;
    background: var(--surface);
  }
  .fallback .title { white-space: normal; }

  .title {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stars {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--heading);
  }

  .sub { font-size: 0.85rem; }
  .empty { padding: 0.55rem 0; }
</style>
