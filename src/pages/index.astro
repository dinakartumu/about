---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PhotoSetCard from '../components/PhotoSetCard.astro';
import { photoUrl } from '../lib/images';

const recent = (await getCollection('photosets'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 4);
const ogImage = recent.length
  ? photoUrl(recent[0].data.cover, { width: 1200, height: 630, fit: 'cover' })
  : undefined;
---
<Layout title="Dinakar Tumu" image={ogImage}>
  <section class="container intro">
    <h1>Dinakar Tumu</h1>
    <p>
      Engineer at <a href="https://pageloop.ai">Pageloop</a>. I spend my weekends
      walking new neighborhoods with a camera — most of what I shoot ends up in
      <a href="/photos">photosets</a>.
    </p>
    <p class="muted">
      <a href="mailto:dinakar91@gmail.com">Email</a> · <a href="https://github.com/dinakartumu">GitHub</a>
    </p>
  </section>

  {recent.length > 0 && (
    <section class="container">
      <h2>Recent photos</h2>
      <div class="grid">
        {recent.map(({ data }) => {
          const coverPhoto = data.photos.find((p) => p.id === data.cover);
          return (
            <PhotoSetCard
              slug={data.slug}
              title={data.title}
              cover={data.cover}
              coverWidth={coverPhoto?.width}
              coverHeight={coverPhoto?.height}
              count={data.photos.length}
              date={data.date}
            />
          );
        })}
      </div>
    </section>
  )}
</Layout>

<style>
  .container { max-width: 44rem; }
  h2 { font-size: 1.1rem; margin: 2rem 0 1rem; }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 3vw, 2rem);
    margin-bottom: 2rem;
  }
</style>
