---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Photo from '../../components/Photo.astro';
import { photoUrl } from '../../lib/images';

export async function getStaticPaths() {
  const sets = await getCollection('photosets');
  return sets.map((set) => ({ params: { set: set.data.slug }, props: { set } }));
}

const { set } = Astro.props;
const { title, description, photos } = set.data;

// Group adjacent portraits into pairs; landscapes stand alone.
type P = (typeof photos)[number];
const isPortrait = (p: P) => p.height > p.width;
const rows: { photos: { photo: P; index: number }[] }[] = [];
for (let i = 0; i < photos.length; i++) {
  if (isPortrait(photos[i]) && i + 1 < photos.length && isPortrait(photos[i + 1])) {
    rows.push({ photos: [{ photo: photos[i], index: i }, { photo: photos[i + 1], index: i + 1 }] });
    i++;
  } else {
    rows.push({ photos: [{ photo: photos[i], index: i }] });
  }
}
const lightboxItems = photos.map((p) => ({
  url: photoUrl(p.id, { width: 2400, fit: 'scale-down' }),
  id: p.id,
  w: p.width,
  h: p.height,
}));
---
<Layout title={`${title} · Photos · Dinakar Tumu`} description={description || `${title} photoset.`}>
  <article class="container">
    <header>
      <h1>{title}</h1>
      {description && <p class="muted">{description}</p>}
      <p class="muted count">{photos.length} photos</p>
    </header>

    <div class="photos">
      {rows.map((row) => (
        <div class={`row ${row.photos.length === 2 ? 'pair' : ''}`}>
          {row.photos.map(({ photo, index }) => (
            <Photo
              photo={photo}
              index={index}
              sizes={row.photos.length === 2 ? '(max-width: 40rem) 100vw, (max-width: 76rem) 50vw, 36rem' : undefined}
            />
          ))}
        </div>
      ))}
    </div>
  </article>

  <dialog id="lightbox" aria-label="Photo viewer">
    <button class="close" aria-label="Close">×</button>
    <button class="prev" aria-label="Previous photo">‹</button>
    <div class="shimmer" aria-hidden="true"></div>
    <img alt="" />
    <button class="next" aria-label="Next photo">›</button>
  </dialog>

  <script
    type="application/json"
    id="lightbox-data"
    set:html={JSON.stringify(lightboxItems).replace(/</g, '\\u003c')}
  />
  <script>
  // Note: data passed via JSON script tag, NOT define:vars — astro 5.x has an open
  // XSS advisory in define:vars sanitization (GHSA-j687-52p2-xcff).
  const lightboxItems = JSON.parse(
    document.getElementById('lightbox-data')!.textContent!
  ) as { url: string; id: string; w: number; h: number }[];
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const img = dialog.querySelector('img')!;
  const shimmer = dialog.querySelector('.shimmer') as HTMLDivElement;
  const prevBtn = dialog.querySelector('.prev') as HTMLButtonElement;
  const nextBtn = dialog.querySelector('.next') as HTMLButtonElement;
  let current = 0;

  // Size the shimmer to the incoming photo's on-screen box (object-fit: contain
  // within 95vw/95vh) so the skeleton matches the image that will replace it.
  function sizeShimmer(w: number, h: number) {
    const scale = Math.min((window.innerWidth * 0.95) / w, (window.innerHeight * 0.95) / h);
    shimmer.style.width = `${Math.round(w * scale)}px`;
    shimmer.style.height = `${Math.round(h * scale)}px`;
  }

  // Photo ids look like "pescadero/DSCF1598"; the set is already in the path,
  // so the URL hash just carries the filename slug, e.g. #DSCF1598.
  const slug = (id: string) => id.split('/').pop()!;
  const indexForSlug = (s: string) => lightboxItems.findIndex((it) => slug(it.id) === s);

  const preloaded = new Set<string>();
  function preload(i: number) {
    if (i < 0 || i >= lightboxItems.length) return;
    const url = lightboxItems[i].url;
    if (preloaded.has(url)) return;
    preloaded.add(url);
    new Image().src = url;
  }

  // Decode the target off-screen before swapping, so we never leave the previous
  // photo on screen or flash a half-loaded one. While it loads we hide the old
  // photo and show a shimmer skeleton (delayed slightly so instant, preloaded
  // swaps don't flicker). A token guards against fast, out-of-order navigation.
  let renderToken = 0;
  function render(i: number) {
    // Bounded (no wrap): clamp, and disable Prev/Next at the ends.
    current = Math.max(0, Math.min(i, lightboxItems.length - 1));
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === lightboxItems.length - 1;
    const item = lightboxItems[current];
    const token = ++renderToken;

    img.classList.add('hidden');
    sizeShimmer(item.w, item.h);
    const shimmerTimer = window.setTimeout(() => {
      if (token === renderToken) shimmer.classList.add('active');
    }, 100);

    const pending = new Image();
    pending.src = item.url;
    pending.decode().catch(() => {}).then(() => {
      if (token !== renderToken) return; // superseded by a newer navigation
      window.clearTimeout(shimmerTimer);
      img.src = item.url;
      img.classList.remove('hidden');
      shimmer.classList.remove('active');
    });

    preload(current + 1);
    preload(current - 1);
  }

  // Opening pushes a history entry (so Back closes the lightbox); navigating
  // within it replaces, keeping the shareable URL in sync without spamming history.
  function open(i: number) {
    render(i);
    history.pushState(null, '', '#' + slug(lightboxItems[current].id));
    if (!dialog.open) dialog.showModal();
  }
  function go(i: number) {
    if (i < 0 || i >= lightboxItems.length) return; // no wrap at the ends
    render(i);
    history.replaceState(null, '', '#' + slug(lightboxItems[current].id));
  }

  document.querySelectorAll<HTMLAnchorElement>('.photo-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      open(Number(link.dataset.index));
    });
  });

  dialog.querySelector('.close')!.addEventListener('click', () => dialog.close());
  dialog.querySelector('.prev')!.addEventListener('click', () => go(current - 1));
  dialog.querySelector('.next')!.addEventListener('click', () => go(current + 1));
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') go(current - 1);
    if (e.key === 'ArrowRight') go(current + 1);
  });
  // Closing (Esc, button, backdrop) drops the hash so the URL is clean again.
  dialog.addEventListener('close', () => {
    if (location.hash) history.replaceState(null, '', location.pathname + location.search);
  });

  // Back/forward and shared deep links: open, navigate, or close to match the URL.
  function syncToHash() {
    const s = decodeURIComponent(location.hash.slice(1));
    if (!s) {
      if (dialog.open) dialog.close();
      return;
    }
    const i = indexForSlug(s);
    if (i < 0) return;
    render(i);
    if (!dialog.open) dialog.showModal();
  }
  window.addEventListener('popstate', syncToHash);
  syncToHash(); // handle a deep link on initial load

  let touchX: number | null = null;
  dialog.addEventListener('touchstart', (e) => (touchX = e.touches[0].clientX), { passive: true });
  dialog.addEventListener('touchend', (e) => {
    if (touchX === null) return;
    const dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 40) go(dx < 0 ? current + 1 : current - 1);
    touchX = null;
  });
  </script>
</Layout>

<style>
  header { max-width: 44rem; margin: 0 auto 2rem; text-align: center; }
  header h1 { margin: 0 0 0.25rem; }
  .count { font-size: 0.85rem; }
  .photos { display: flex; flex-direction: column; gap: 2.5rem; }
  .row.pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 40rem) {
    .row.pair { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  dialog {
    border: 0;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
  }
  dialog::backdrop { background: rgba(0, 0, 0, 0.95); }
  dialog img {
    max-width: 95vw;
    max-height: 95vh;
    width: auto;
    height: auto;
    margin: auto;
    position: absolute;
    inset: 0;
    object-fit: contain;
    transition: opacity 0.2s ease;
  }
  dialog img.hidden { opacity: 0; }

  .shimmer {
    display: none;
    position: absolute;
    inset: 0;
    margin: auto;
    border-radius: 4px;
    background-color: #17171a;
    background-image: linear-gradient(
      100deg,
      transparent 30%,
      rgba(255, 255, 255, 0.06) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
    background-repeat: no-repeat;
  }
  .shimmer.active { display: block; animation: shimmer 1.2s ease-in-out infinite; }
  @keyframes shimmer {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .shimmer.active { animation: none; }
  }
  dialog button {
    position: fixed;
    z-index: 1;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    border: 0;
    font-size: 1.6rem;
    line-height: 1;
    padding: 0.5rem 0.9rem;
    border-radius: 4px;
    cursor: pointer;
  }
  dialog button:disabled {
    opacity: 0.25;
    cursor: default;
  }
  .close { top: 1rem; right: 1rem; }
  .prev { left: 1rem; top: 50%; transform: translateY(-50%); }
  .next { right: 1rem; top: 50%; transform: translateY(-50%); }
</style>
