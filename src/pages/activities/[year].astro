---
import ActivitiesYear from '../../components/ActivitiesYear.astro';
import Layout from '../../layouts/Layout.astro';
import { rewindFetch, shapeRunningYears } from '../../lib/rewind';

export async function getStaticPaths() {
  const currentYear = new Date().getUTCFullYear();
  // Memoized — the page components reuse this exact call for the headlines.
  const summaries = shapeRunningYears(
    await rewindFetch<Parameters<typeof shapeRunningYears>[0]>('/v1/running/stats/years')
  );
  const firstYear =
    summaries.length > 0 ? Math.min(...summaries.map((s) => s.year)) : currentYear;
  const paths = [];
  for (let year = firstYear; year <= currentYear; year++) {
    paths.push({ params: { year: String(year) } });
  }
  return paths;
}

const year = Number(Astro.params.year);
---
<Layout
  title={`Activities ${year} · Dinakar Tumu`}
  description={`Dinakar Tumu's runs in ${year} — distance, pace, and a monthly chart.`}
>
  <ActivitiesYear year={year} />
</Layout>
