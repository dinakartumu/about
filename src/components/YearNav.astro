---
/**
 * Compact inline year switcher: "2026 · 2025 · 2024 …". The newest year
 * links to the bare base path (that page renders the current year); every
 * other year links to its own subpage. No client JS.
 */
interface Props {
  basePath: string; // e.g. "/listening", no trailing slash
  years: number[]; // rendered in the given order, typically newest first
  current: number;
}
const { basePath, years, current } = Astro.props;

const newest = Math.max(...years);
const hrefFor = (year: number) => (year === newest ? basePath : `${basePath}/${year}/`);
---
<nav class="year-nav" aria-label="Year">
  <ul>
    {years.map((year) => (
      <li>
        <a href={hrefFor(year)} aria-current={year === current ? 'page' : undefined}>{year}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }
  li { display: flex; gap: 0.35rem; }
  li + li::before { content: '·'; color: var(--muted); }
  a { color: var(--muted); }
  a:hover { color: var(--heading); }
  a[aria-current='page'] { color: var(--heading); font-weight: 500; }
</style>
