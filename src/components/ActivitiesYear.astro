---
/**
 * One activities year: inline year/month header, a monthly-activities chart
 * stacked by sport type, and the activity list — each row carries a circular
 * sport-glyph chip, GPS activities add a small route thumbnail after it (rows
 * without a route keep the plain chip+name layout), the sub line joins the
 * date with the activity's city/state, and the figures adapt to the sport:
 * distance sports show miles (plus pace for runs), stationary sports show
 * duration and calories. Rendered by /activities (current year) and
 * /activities/{year}. Clicking a chart bar (or the month dropdown) filters the
 * list to that month; the header owns the selection and dims the other months.
 *
 * /v1/running/stats/years — one memoized call — lists every year that has
 * activities; a year absent from it renders its empty state without touching
 * the per-year endpoints (the year rollup 404s when a year has no runs). The
 * Strava backfill is still importing history, so empty years are expected.
 *
 * The grid shows the complete year: /v1/running/activities caps limit at 100
 * and returns a pagination envelope, so the build walks page=1.. until a short
 * page arrives (the busiest year is ~150 activities, so 1-2 pages).
 */
import {
  activityFigures,
  buildGenreStacks,
  ACTIVITIES_PALETTE,
  rewindFetch,
  shapeActivities,
  shapeRunningYears,
  type RunActivity,
  type StackMonth,
} from '../lib/rewind';
import SportIcon from './SportIcon.astro';
import StackedMonthlyChart from './StackedMonthlyChart.astro';
import MonthYearHeader from './MonthYearHeader.astro';

type YearsJson = Parameters<typeof shapeRunningYears>[0];
type ActivitiesJson = Parameters<typeof shapeActivities>[0];

interface Props {
  year: number;
}
const { year } = Astro.props;

const now = new Date();
const currentYear = now.getUTCFullYear();

const summaries = shapeRunningYears(await rewindFetch<YearsJson>('/v1/running/stats/years'));
const firstYear = summaries.length > 0 ? Math.min(...summaries.map((s) => s.year)) : currentYear;
const years: number[] = [];
for (let y = currentYear; y >= firstYear; y--) years.push(y);

const summary = summaries.find((s) => s.year === year) ?? null;

// Millisecond-precision bounds: the API compares timestamp strings, and the
// stored values carry milliseconds — "T00:00:00Z" sorts after "T00:00:00.000Z"
// and would drop activities logged at midnight on Jan 1.
const yearQuery = `from=${encodeURIComponent(`${year}-01-01T00:00:00.000Z`)}&to=${encodeURIComponent(`${year}-12-31T23:59:59.999Z`)}`;
const PAGE_LIMIT = 100; // the API's hard cap on /v1/running/activities
const MAX_PAGES = 30; // safety stop well past the busiest year (~150 activities)

// Any failure throws and fails the build — never publish a page with
// missing sections. Years without activities skip the list fetches. Year
// pages walk the pagination envelope for the complete year.
const runs: RunActivity[] = [];
if (summary) {
  for (let page = 1; page <= MAX_PAGES; page++) {
    const batch = shapeActivities(
      await rewindFetch<ActivitiesJson>(
        `/v1/running/activities?${yearQuery}&limit=${PAGE_LIMIT}&page=${page}`
      )
    );
    runs.push(...batch);
    if (batch.length < PAGE_LIMIT) break;
  }
}

// Per-month sport breakdown → stacked chart, and per-month counts → header
// count (computed client-side from the full-year activity list; no API
// endpoint needed).
const monthlySport: Record<string, number>[] = Array.from({ length: 12 }, () => ({}));
const countByMonth: number[] = new Array(12).fill(0);
for (const r of runs) {
  const monthIndex = r.monthIndex;
  if (monthIndex < 0 || monthIndex > 11) continue;
  monthlySport[monthIndex][r.sport] = (monthlySport[monthIndex][r.sport] ?? 0) + 1;
  countByMonth[monthIndex] += 1;
}
const stacks: StackMonth[] = buildGenreStacks(monthlySport, countByMonth, ACTIVITIES_PALETTE);
const chartHasData = stacks.some((s) => s.total > 0);
const monthsAvailable = year === currentYear ? now.getUTCMonth() + 1 : 12;

const linkAttrs = (link: string | null) =>
  link ? { href: link, target: '_blank', rel: 'noopener' } : {};
---
<MonthYearHeader
  title="Activities"
  basePath="/activities"
  year={year}
  years={years}
  total={runs.length}
  countByMonth={countByMonth}
  nounSingular="activity"
  nounPlural="activities"
  monthsAvailable={monthsAvailable}
/>

<section class="container chart">
  {chartHasData ? (
    <div class="chart-card">
      <StackedMonthlyChart
        months={stacks}
        caption="activities"
        ariaLabel={`Activities per month in ${year}, by type`}
      />
    </div>
  ) : (
    <p class="muted no-data">No activities in {year}.</p>
  )}
</section>

<section class="container">
  <h2>Activities · {year}</h2>
  <ol class="list" role="list">
    {runs.map((r) => (
      <li data-month={r.monthIndex}>
        <a class="row" {...linkAttrs(r.stravaUrl)}>
          <span class="meta">
            <span class="name-row">
              <SportIcon sport={r.sport} />
              {r.routePath && (
                <svg class="route" viewBox="0 0 64 40" width="42" height="26" aria-hidden="true">
                  <path
                    d={r.routePath}
                    fill="none"
                    stroke="var(--accent)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              <span class="name">{r.name}</span>
            </span>
            <span class="sub muted">{[r.date, r.place].filter(Boolean).join(' · ')}</span>
          </span>
          <span class="figures muted">{activityFigures(r)}</span>
        </a>
      </li>
    ))}
    {runs.length === 0 && <li class="empty muted">No activities in {year}.</li>}
  </ol>
</section>

<style>
  .container { max-width: 44rem; }
  .name-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* GPS route thumbnail — absent entirely on routeless rows, so they keep
     the plain chip+name layout with no empty gap. */
  .route {
    flex-shrink: 0;
    display: block;
    background: var(--surface);
    border-radius: 6px;
  }

  .chart { margin-top: 1.5rem; }
  .chart-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 1.25rem 1rem 0.75rem;
  }
  .no-data { margin: 1rem 0 0; }

  .list li.hidden { display: none; }

  h2 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 2.5rem 0 1rem;
  }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 44rem;
  }
  .list li + li { border-top: 1px solid var(--surface); }
  .row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0;
  }
  a.row[href]:hover .name { color: var(--accent); }
  .meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .name {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub { font-size: 0.85rem; }

  .figures {
    margin-left: auto;
    white-space: nowrap;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  .empty { padding: 0.55rem 0; }
</style>

<script>
  // The header resolves month selection and dispatches `chart:setMonth`; filter
  // the activity list to that month (show all when null).
  const rows = Array.from(document.querySelectorAll<HTMLLIElement>('.list > li[data-month]'));
  document.addEventListener('chart:setMonth', (e) => {
    const month = (e as CustomEvent).detail?.month as number | null;
    for (const li of rows) {
      const m = Number(li.getAttribute('data-month'));
      li.classList.toggle('hidden', month != null && m !== month);
    }
  });
</script>
