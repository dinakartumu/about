---
/**
 * One activities year: headline, year switcher, monthly-runs chart, and the
 * activity list — each row carries a circular sport-glyph chip, GPS
 * activities add a small route thumbnail after it (rows without a route
 * keep the plain chip+name layout), the sub line joins the date with the
 * activity's city/state, and the figures adapt to the sport: distance
 * sports show miles (plus pace for runs), stationary sports show duration
 * and calories. Rendered by both
 * /activities (global lifetime headline, recent 20) and /activities/{year}
 * (year-scoped headline and every activity of the year).
 *
 * /v1/running/stats/years — one memoized call — lists every year that has
 * activities; a year absent from it renders its empty state without touching
 * the per-year endpoints (the year rollup 404s when a year has no runs). The
 * Strava backfill is still importing history, so empty years are expected.
 *
 * Year pages list the complete year: /v1/running/activities caps limit at
 * 100 and returns a pagination envelope, so the build walks page=1.. until a
 * short page arrives (the busiest year is ~150 activities, so 1-2 pages).
 */
import {
  activityFigures,
  fmtDuration,
  rewindFetch,
  runningMonthlyPoints,
  shapeActivities,
  shapeRunningStats,
  shapeRunningYears,
  shapeTrends,
  trendsAriaLabel,
  type RunActivity,
  type TrendPoint,
} from '../lib/rewind';
import BarChart from './BarChart.astro';
import SportIcon from './SportIcon.astro';
import YearNav from './YearNav.astro';

type StatsJson = Parameters<typeof shapeRunningStats>[0];
type YearsJson = Parameters<typeof shapeRunningYears>[0];
type RollupJson = Parameters<typeof runningMonthlyPoints>[0];
type ActivitiesJson = Parameters<typeof shapeActivities>[0];

interface Props {
  year: number;
  global?: boolean;
}
const { year, global: isGlobal = false } = Astro.props;

const now = new Date();
const currentYear = now.getUTCFullYear();

const summaries = shapeRunningYears(await rewindFetch<YearsJson>('/v1/running/stats/years'));
const firstYear = summaries.length > 0 ? Math.min(...summaries.map((s) => s.year)) : currentYear;
const years: number[] = [];
for (let y = currentYear; y >= firstYear; y--) years.push(y);

const summary = summaries.find((s) => s.year === year) ?? null;

const n = (v: number) => Math.round(v).toLocaleString('en-US');

// Millisecond-precision bounds: the API compares timestamp strings, and the
// stored values carry milliseconds — "T00:00:00Z" sorts after "T00:00:00.000Z"
// and would drop activities logged at midnight on Jan 1.
const yearQuery = `from=${encodeURIComponent(`${year}-01-01T00:00:00.000Z`)}&to=${encodeURIComponent(`${year}-12-31T23:59:59.999Z`)}`;
const PAGE_LIMIT = 100; // the API's hard cap on /v1/running/activities
const MAX_PAGES = 30; // safety stop well past the busiest year (~150 activities)

// Any failure throws and fails the build — never publish a page with
// missing sections. Years without activities skip the rollup and list
// fetches. The global page shows the current year's 20 most recent; year
// pages walk the pagination envelope for the complete year.
let trendPoints: TrendPoint[] = shapeTrends({ data: [] }, year, now);
const runs: RunActivity[] = [];
if (summary) {
  trendPoints = runningMonthlyPoints(
    await rewindFetch<RollupJson>(`/v1/running/year/${year}`),
    year,
    now
  );
  if (isGlobal) {
    runs.push(
      ...shapeActivities(
        await rewindFetch<ActivitiesJson>(`/v1/running/activities?${yearQuery}&limit=20`)
      )
    );
  } else {
    for (let page = 1; page <= MAX_PAGES; page++) {
      const batch = shapeActivities(
        await rewindFetch<ActivitiesJson>(
          `/v1/running/activities?${yearQuery}&limit=${PAGE_LIMIT}&page=${page}`
        )
      );
      runs.push(...batch);
      if (batch.length < PAGE_LIMIT) break;
    }
  }
}

// The year headline counts every fetched activity — the year summary's
// total_runs only counts run-type sports, which undercounts gym-heavy years.
let headline: string;
let subline: string | null = null;
if (isGlobal) {
  const stats = shapeRunningStats(await rewindFetch<StatsJson>('/v1/running/stats'));
  const parts = [
    `${n(stats.totalActivities)} Activities`,
    `${n(stats.totalMiles)} Miles`,
    `${n(stats.totalDurationS / 3600)} Hours`,
  ];
  headline = parts.join(' · ');
} else if (summary) {
  headline = `${n(runs.length)} ${runs.length === 1 ? 'activity' : 'activities'} in ${year}`;
  const parts = [`${n(summary.totalMiles)} ${summary.totalMiles === 1 ? 'mile' : 'miles'}`];
  parts.push(fmtDuration(summary.totalDurationS));
  if (summary.avgPace) parts.push(`${summary.avgPace} avg pace`);
  subline = parts.join(' · ');
} else {
  headline = `No activities in ${year}`;
}

const listHeading = isGlobal ? 'Recent Activities' : `Activities in ${year}`;
const emptyText = isGlobal ? 'No activities yet this year.' : `No activities in ${year}.`;

const linkAttrs = (link: string | null) =>
  link ? { href: link, target: '_blank', rel: 'noopener' } : {};
---
<section class="container head">
  <div>
    <h1>{headline}</h1>
    {subline && <p class="subline muted">{subline}</p>}
    <YearNav basePath="/activities" years={years} current={year} />
  </div>
</section>

<section class="container chart">
  <BarChart points={trendPoints} ariaLabel={trendsAriaLabel(trendPoints, 'runs')} />
</section>

<section class="container">
  <h2>{listHeading}</h2>
  <ol class="list" role="list">
    {runs.map((r) => (
      <li>
        <a class="row" {...linkAttrs(r.stravaUrl)}>
          <span class="meta">
            <span class="name-row">
              <SportIcon sport={r.sport} />
              {r.routePath && (
                <svg class="route" viewBox="0 0 64 40" width="42" height="26" aria-hidden="true">
                  <path
                    d={r.routePath}
                    fill="none"
                    stroke="var(--accent)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              <span class="name">{r.name}</span>
            </span>
            <span class="sub muted">{[r.date, r.place].filter(Boolean).join(' · ')}</span>
          </span>
          <span class="figures muted">{activityFigures(r)}</span>
        </a>
      </li>
    ))}
    {runs.length === 0 && <li class="empty muted">{emptyText}</li>}
  </ol>
</section>

<style>
  .container { max-width: 44rem; }
  .name-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* GPS route thumbnail — absent entirely on routeless rows, so they keep
     the plain chip+name layout with no empty gap. */
  .route {
    flex-shrink: 0;
    display: block;
    background: var(--surface);
    border-radius: 6px;
  }

  .head h1 { margin-bottom: 0.5rem; }
  .subline {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
  }

  .chart { margin-top: 1.75rem; }

  h2 { font-size: 1.1rem; margin: 2.25rem 0 0.75rem; }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 44rem;
  }
  .list li + li { border-top: 1px solid var(--surface); }
  .row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0;
  }
  a.row[href]:hover .name { color: var(--accent); }
  .meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .name {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub { font-size: 0.85rem; }

  .figures {
    margin-left: auto;
    white-space: nowrap;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  .empty { padding: 0.55rem 0; }
</style>
