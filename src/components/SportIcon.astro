---
/**
 * A 26px circular chip with a minimal stroke-style glyph for a Strava sport.
 * Accepts either the raw sport_type ("WeightTraining") or the humanized
 * label ("Weight Training") — spaces are stripped before lookup. Unknown
 * sports fall back to a map pin. Paths are hand-drawn in the Feather idiom:
 * 24px grid, 2px round strokes, no fill, rendered at 16px in currentColor.
 */
interface Props {
  sport: string;
}
const { sport } = Astro.props;

// Each glyph is a list of path data strings drawn on a 24x24 grid.
const GLYPHS: Record<string, string[]> = {
  runner: [
    'M14.5 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
    'M13.5 7.5L11 12l3 3-2 6',
    'M11 12l-3.5 1.5L5 17.5',
    'M13 8.5l4 2 3-1.5',
    'M13 8.5l-4 .5',
  ],
  bicycle: [
    'M6 17.5m-3.5 0a3.5 3.5 0 1 0 7 0a3.5 3.5 0 1 0-7 0',
    'M18 17.5m-3.5 0a3.5 3.5 0 1 0 7 0a3.5 3.5 0 1 0-7 0',
    'M6 17.5l3.5-7.5h6l2.5 7.5',
    'M9.5 10L13 17.5H6',
    'M14 6.5h3l1 3.5',
  ],
  walker: [
    'M13 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
    'M13 7.5l-1 5-2.5 8.5',
    'M12 12.5l2.5 3.5 1 5.5',
    'M12.5 9.5l-3.5 2-1 3.5',
    'M12.5 9.5l3.5 1.5 2 2.5',
  ],
  mountain: ['M2 19.5l6.5-11 3.5 5.5 3-7 7 12.5z'],
  dumbbell: [
    'M6.5 6.5v11',
    'M17.5 6.5v11',
    'M3 9.5v5',
    'M21 9.5v5',
    'M6.5 12h11',
  ],
  pulse: ['M22 12h-4l-3 9L9 3l-3 9H2'],
  waves: [
    'M2 8.5c1.7-2 3.3-2 5 0s3.3 2 5 0 3.3-2 5 0 3.3 2 5 0',
    'M2 15.5c1.7-2 3.3-2 5 0s3.3 2 5 0 3.3-2 5 0 3.3 2 5 0',
  ],
  lotus: [
    'M12 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
    'M12 8.5v4',
    'M12 10.5l-5 2.5',
    'M12 10.5l5 2.5',
    'M4.5 18c2.5-4 12.5-4 15 0',
    'M4.5 18h15',
  ],
  pin: [
    'M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z',
    'M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z',
  ],
};

const SPORT_GLYPHS: Record<string, string> = {
  Run: 'runner',
  TrailRun: 'runner',
  VirtualRun: 'runner',
  Ride: 'bicycle',
  VirtualRide: 'bicycle',
  EBikeRide: 'bicycle',
  GravelRide: 'bicycle',
  MountainBikeRide: 'bicycle',
  Walk: 'walker',
  Hike: 'mountain',
  WeightTraining: 'dumbbell',
  Workout: 'pulse',
  Crossfit: 'pulse',
  Swim: 'waves',
  Yoga: 'lotus',
};

const key = SPORT_GLYPHS[sport.replace(/\s+/g, '')] ?? 'pin';
const paths = GLYPHS[key];
---
<span class="chip" aria-hidden="true">
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    {paths.map((d) => <path d={d} />)}
  </svg>
</span>

<style>
  .chip {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #e9e4da;
    color: #4a463f;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .chip svg { display: block; }
</style>
