---
/**
 * One movies year: inline year/month header, a monthly-watches chart stacked by
 * genre, and the poster grid. Rendered by /movies (current year) and
 * /movies/{year}. Clicking a chart bar (or the month dropdown) filters the grid
 * to that month; the header owns the selection and dims the other months.
 *
 * A single wide trends probe — memoized across every movies page — supplies the
 * first year with a watch and the year navigation range. The grid shows the
 * complete year: /v1/watching/recent caps limit at 50 and returns no pagination
 * envelope, so the build walks page=1.. until a short page arrives.
 */
import {
  buildGenreStacks,
  MOVIES_PALETTE,
  rewindFetch,
  shapeRecentWatches,
  shapeTrends,
  trendsFirstYear,
  wideTrendsPath,
  type RecentWatch,
  type StackMonth,
} from '../lib/rewind';
import StackedMonthlyChart from './StackedMonthlyChart.astro';
import MonthYearHeader from './MonthYearHeader.astro';

type RecentJson = Parameters<typeof shapeRecentWatches>[0];
type TrendsJson = Parameters<typeof shapeTrends>[0];

interface Props {
  year: number;
}
const { year } = Astro.props;

const now = new Date();
const currentYear = now.getUTCFullYear();

const trends = await rewindFetch<TrendsJson>(wideTrendsPath('watching', currentYear));
const firstYear = trendsFirstYear(trends);
const years: number[] = [];
for (let y = currentYear; y >= firstYear; y--) years.push(y);

const trendPoints = shapeTrends(trends, year, now);
const yearWatchCount = trendPoints.reduce((sum, p) => sum + p.value, 0);

// Millisecond-precision bounds: the API compares timestamp strings and stored
// values carry milliseconds — "T00:00:00Z" sorts after "T00:00:00.000Z" and
// would drop watches logged at midnight on Jan 1.
const yearQuery = `from=${encodeURIComponent(`${year}-01-01T00:00:00.000Z`)}&to=${encodeURIComponent(`${year}-12-31T23:59:59.999Z`)}`;
const PAGE_LIMIT = 50;
const MAX_PAGES = 20;

const watches: RecentWatch[] = [];
if (yearWatchCount > 0) {
  for (let page = 1; page <= MAX_PAGES; page++) {
    const batch = shapeRecentWatches(
      await rewindFetch<RecentJson>(
        `/v1/watching/recent?${yearQuery}&limit=${PAGE_LIMIT}&page=${page}`
      )
    );
    watches.push(...batch);
    if (batch.length < PAGE_LIMIT) break;
  }
}

// Per-month watch counts (drive the header count + the chart bar length) and
// per-month genre breakdown (chart segments).
const countByMonth: number[] = new Array(12).fill(0);
for (const w of watches) if (w.monthIndex >= 0 && w.monthIndex <= 11) countByMonth[w.monthIndex]++;

type GenresJson = { data: { period: string; genres: Record<string, number>; total: number }[] };
const genresJson = await rewindFetch<GenresJson>(`/v1/watching/genres?${yearQuery}&limit=8`);
const monthlyGenres: (Record<string, number> | undefined)[] = new Array(12);
for (const bucket of genresJson.data) {
  if (!bucket.period.startsWith(`${year}-`)) continue;
  const m = Number(bucket.period.slice(5, 7)) - 1;
  if (m >= 0 && m <= 11) monthlyGenres[m] = bucket.genres;
}

const stacks: StackMonth[] = buildGenreStacks(monthlyGenres, countByMonth, MOVIES_PALETTE);
const chartHasData = stacks.some((s) => s.total > 0);
const monthsAvailable = year === currentYear ? now.getUTCMonth() + 1 : 12;

const linkAttrs = (link: string | null) =>
  link ? { href: link, target: '_blank', rel: 'noopener' } : {};
---
<MonthYearHeader
  title="Movies"
  basePath="/movies"
  year={year}
  years={years}
  total={watches.length}
  countByMonth={countByMonth}
  nounSingular="film"
  nounPlural="films"
  monthsAvailable={monthsAvailable}
/>

<section class="container chart">
  {chartHasData ? (
    <div class="chart-card">
      <StackedMonthlyChart
        months={stacks}
        caption="films"
        ariaLabel={`Movies watched per month in ${year}, by genre`}
      />
    </div>
  ) : (
    <p class="muted no-data">No films in {year}.</p>
  )}
</section>

<section class="container">
  <h2>Watched · {year}</h2>
  <ol class="grid" role="list">
    {watches.map((m) => (
      <li data-month={m.monthIndex}>
        <a class="tile" {...linkAttrs(m.tmdbUrl)}>
          {m.image ? (
            <img
              class="poster"
              src={m.image.url}
              alt=""
              width="200"
              height="300"
              loading="lazy"
              decoding="async"
              style={`background:${m.image.dominantColor}`}
            />
          ) : (
            <span class="poster fallback">
              <span class="title">{m.title}</span>
              {m.year !== null && <span class="sub muted">{m.year}</span>}
            </span>
          )}
          {m.image && (
            <span class="title">
              {m.title}
              {m.year !== null && <span class="muted"> ({m.year})</span>}
            </span>
          )}
          {m.stars && m.rating != null && (
            <span class="stars" role="img" aria-label={`Rated ${m.rating} out of 5`}>{m.stars}</span>
          )}
          <span class="sub muted">{m.watchedDate}{m.rewatch && ' · Rewatch'}</span>
        </a>
      </li>
    ))}
    {watches.length === 0 && <li class="empty muted">Nothing watched in {year}.</li>}
  </ol>
</section>

<style>
  .container { max-width: 44rem; }

  .chart { margin-top: 1.5rem; }
  .chart-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 1.25rem 1rem 0.75rem;
  }
  .no-data { margin: 1rem 0 0; }

  h2 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 2.5rem 0 1rem;
  }

  .grid :global(li.hidden) { display: none; }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.5rem 1rem;
  }

  .tile { display: flex; flex-direction: column; }
  a.tile[href]:hover .title { color: var(--accent); }

  .poster {
    width: 100%;
    aspect-ratio: 2 / 3;
    height: auto;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 0.4rem;
  }

  .fallback {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem;
    text-align: center;
    background: var(--surface);
  }
  .fallback .title { white-space: normal; }

  .title {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stars {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--heading);
  }

  .sub { font-size: 0.85rem; }
  .empty { padding: 0.55rem 0; }
</style>

<script>
  // The header resolves month selection and dispatches `chart:setMonth`; filter
  // the poster grid to that month (show all when null).
  const tiles = Array.from(document.querySelectorAll<HTMLLIElement>('.grid > li[data-month]'));
  document.addEventListener('chart:setMonth', (e) => {
    const month = (e as CustomEvent).detail?.month as number | null;
    for (const li of tiles) {
      const m = Number(li.getAttribute('data-month'));
      li.classList.toggle('hidden', month != null && m !== month);
    }
  });
</script>
