---
/**
 * One movies year: headline, year switcher, monthly-watches chart, and the
 * poster grid. Rendered by both /movies (global headline, recent grid) and
 * /movies/{year} (year-scoped headline and grid).
 *
 * A single wide trends probe — memoized across every movies page — supplies
 * the first year with a watch, the year navigation range, and each year's
 * chart, so year pages only add the rollup headline and their poster grid.
 */
import {
  rewindFetch,
  shapeRecentWatches,
  shapeTrends,
  shapeWatchingStats,
  shapeWatchingYear,
  trendsAriaLabel,
  trendsFirstYear,
  wideTrendsPath,
  type RecentWatch,
} from '../lib/rewind';
import BarChart from './BarChart.astro';
import YearNav from './YearNav.astro';

type StatsJson = Parameters<typeof shapeWatchingStats>[0];
type RecentJson = Parameters<typeof shapeRecentWatches>[0];
type TrendsJson = Parameters<typeof shapeTrends>[0];
type YearJson = Parameters<typeof shapeWatchingYear>[0];

interface Props {
  year: number;
  global?: boolean;
}
const { year, global: isGlobal = false } = Astro.props;

const now = new Date();
const currentYear = now.getUTCFullYear();

const trends = await rewindFetch<TrendsJson>(wideTrendsPath('watching', currentYear));
const firstYear = trendsFirstYear(trends);
const years: number[] = [];
for (let y = currentYear; y >= firstYear; y--) years.push(y);

const trendPoints = shapeTrends(trends, year, now);
const yearWatchCount = trendPoints.reduce((sum, p) => sum + p.value, 0);

const n = (v: number) => Math.round(v).toLocaleString('en-US');
const films = (count: number) => `${n(count)} ${count === 1 ? 'film' : 'films'}`;

// Any failure throws and fails the build — never publish a page with
// missing sections. Empty years skip their rollup and grid fetches (the
// rollup 404s when a year has no watches).
let headline: string;
if (isGlobal) {
  const stats = shapeWatchingStats(await rewindFetch<StatsJson>('/v1/watching/stats'));
  headline = `${n(stats.totalMovies)} Films · ${n(stats.moviesThisYear)} This Year · ${n(stats.totalHours)} Hours`;
} else if (yearWatchCount > 0) {
  const rollup = shapeWatchingYear(await rewindFetch<YearJson>(`/v1/watching/year/${year}`));
  headline = `${films(rollup.totalMovies)} in ${year}`;
} else {
  headline = `No films in ${year}`;
}

const yearQuery = `from=${encodeURIComponent(`${year}-01-01T00:00:00Z`)}&to=${encodeURIComponent(`${year}-12-31T23:59:59Z`)}`;
const gridPath = isGlobal
  ? '/v1/watching/recent?limit=24'
  : `/v1/watching/recent?${yearQuery}&limit=24`;
const watches: RecentWatch[] =
  isGlobal || yearWatchCount > 0
    ? shapeRecentWatches(await rewindFetch<RecentJson>(gridPath))
    : [];

const gridHeading = isGlobal ? 'Recently Watched' : `Recently Watched in ${year}`;
const emptyText = isGlobal ? 'Nothing watched yet.' : `Nothing watched in ${year}.`;

const linkAttrs = (link: string | null) =>
  link ? { href: link, target: '_blank', rel: 'noopener' } : {};
---
<section class="container head">
  <h1>{headline}</h1>
  <YearNav basePath="/movies" years={years} current={year} />
</section>

<section class="container chart">
  <BarChart points={trendPoints} ariaLabel={trendsAriaLabel(trendPoints, 'movies')} />
</section>

<section class="container">
  <h2>{gridHeading}</h2>
  <ol class="grid" role="list">
    {watches.map((m) => (
      <li>
        <a class="tile" {...linkAttrs(m.tmdbUrl)}>
          {m.image ? (
            <img
              class="poster"
              src={m.image.url}
              alt=""
              width="200"
              height="300"
              loading="lazy"
              decoding="async"
              style={`background:${m.image.dominantColor}`}
            />
          ) : (
            <span class="poster fallback">
              <span class="title">{m.title}</span>
              {m.year !== null && <span class="sub muted">{m.year}</span>}
            </span>
          )}
          {m.image && (
            <span class="title">
              {m.title}
              {m.year !== null && <span class="muted"> ({m.year})</span>}
            </span>
          )}
          {m.stars && m.rating != null && (
            <span class="stars" role="img" aria-label={`Rated ${m.rating} out of 5`}>{m.stars}</span>
          )}
          <span class="sub muted">{m.watchedDate}{m.rewatch && ' · Rewatch'}</span>
        </a>
      </li>
    ))}
    {watches.length === 0 && <li class="empty muted">{emptyText}</li>}
  </ol>
</section>

<style>
  .container { max-width: 44rem; }
  .head h1 { margin-bottom: 0.5rem; }

  .chart { margin-top: 1.75rem; }

  h2 { font-size: 1.1rem; margin: 2.25rem 0 0.75rem; }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.5rem 1rem;
  }

  .tile { display: flex; flex-direction: column; }
  a.tile[href]:hover .title { color: var(--accent); }

  .poster {
    width: 100%;
    aspect-ratio: 2 / 3;
    height: auto;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 0.4rem;
  }

  /* Title card shown while a poster is still processing (image null). */
  .fallback {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem;
    text-align: center;
    background: var(--surface);
  }
  .fallback .title { white-space: normal; }

  .title {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stars {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--heading);
  }

  .sub { font-size: 0.85rem; }
  .empty { padding: 0.55rem 0; }
</style>
