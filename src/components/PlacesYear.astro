---
/**
 * One places year: headline, year switcher, monthly check-ins chart, and the
 * year's top categories/cities/venues (year-scoped /v1/places/stats via
 * from/to). Rendered by both /places (global all-time headline, current-year
 * top lists) and /places/{year} (year-scoped headline and lists).
 *
 * The recent check-in list appears only on the index and the current-year
 * page — five entries. Historical years show just the headline, chart, and
 * the three top lists.
 *
 * A single wide trends probe — memoized across every places page — supplies
 * the first year with a check-in, the year navigation range, each year's
 * chart, and the year headline (the sum of that year's monthly counts).
 *
 * Venue and category icons are Foursquare's 64px dark-gray-on-transparent
 * glyphs; they are inverted on the dark theme only (see the .icon rules).
 */
import {
  rewindFetch,
  shapePlacesStats,
  shapeRecentCheckins,
  shapeTrends,
  trendsAriaLabel,
  trendsFirstYear,
  wideTrendsPath,
  type PlacesStats,
  type RecentCheckin,
} from '../lib/rewind';
import BarChart from './BarChart.astro';
import YearNav from './YearNav.astro';

type StatsJson = Parameters<typeof shapePlacesStats>[0];
type RecentJson = Parameters<typeof shapeRecentCheckins>[0];
type TrendsJson = Parameters<typeof shapeTrends>[0];

interface Props {
  year: number;
  global?: boolean;
}
const { year, global: isGlobal = false } = Astro.props;

const now = new Date();
const currentYear = now.getUTCFullYear();

const trends = await rewindFetch<TrendsJson>(wideTrendsPath('places', currentYear));
const firstYear = trendsFirstYear(trends);
const years: number[] = [];
for (let y = currentYear; y >= firstYear; y--) years.push(y);

const trendPoints = shapeTrends(trends, year, now);
const yearCheckinCount = trendPoints.reduce((sum, p) => sum + p.value, 0);

const n = (v: number) => Math.round(v).toLocaleString('en-US');
const checkinNoun = (count: number) => (count === 1 ? 'check-in' : 'check-ins');

// Any failure throws and fails the build — never publish a page with
// missing sections. Empty years skip the year-scoped fetches entirely.
let headline: string;
if (isGlobal) {
  // The index headline stays global all-time; only the top lists below are
  // scoped to the current year.
  const allTime = shapePlacesStats(await rewindFetch<StatsJson>('/v1/places/stats'));
  headline = `${n(allTime.total)} Check-ins · ${n(allTime.uniqueVenues)} Venues · ${n(allTime.thisYear)} This Year`;
} else if (yearCheckinCount > 0) {
  headline = `${n(yearCheckinCount)} ${checkinNoun(yearCheckinCount)} in ${year}`;
} else {
  headline = `No check-ins in ${year}`;
}

// Millisecond-precision bounds: the API compares timestamp strings, and the
// stored values carry milliseconds — "T00:00:00Z" sorts after "T00:00:00.000Z"
// and would drop check-ins logged at midnight on Jan 1.
const yearQuery = `from=${encodeURIComponent(`${year}-01-01T00:00:00.000Z`)}&to=${encodeURIComponent(`${year}-12-31T23:59:59.999Z`)}`;

// Year-scoped top lists on every page (the index uses the current year's
// range too). Years without check-ins render the empty-list fallbacks.
const stats: PlacesStats | null =
  isGlobal || yearCheckinCount > 0
    ? shapePlacesStats(await rewindFetch<StatsJson>(`/v1/places/stats?${yearQuery}`))
    : null;

// The recent list only appears on the index and the current-year page.
const showRecent = isGlobal || year === currentYear;
const listPath = isGlobal
  ? '/v1/places/recent?limit=5'
  : `/v1/places/recent?${yearQuery}&limit=5`;
const checkins: RecentCheckin[] =
  showRecent && (isGlobal || yearCheckinCount > 0)
    ? shapeRecentCheckins(await rewindFetch<RecentJson>(listPath))
    : [];

const listHeading = isGlobal ? 'Recent Check-ins' : `Recent Check-ins in ${year}`;
const emptyText = isGlobal ? 'No check-ins yet.' : `No check-ins in ${year}.`;
---
<section class="container head">
  <h1>{headline}</h1>
  <YearNav basePath="/places" years={years} current={year} />
</section>

<section class="container chart">
  <BarChart points={trendPoints} ariaLabel={trendsAriaLabel(trendPoints, 'check-ins')} />
</section>

{showRecent && (
  <section class="container">
    <h2>{listHeading}</h2>
    <ol class="list" role="list">
      {checkins.map((c) => (
        <li>
          <div class="row">
            <span class="meta">
              <span class="name-row">
                {c.icon && (
                  <img class="icon" src={c.icon} alt="" width="20" height="20" loading="lazy" decoding="async" />
                )}
                <span class="name">{c.venueName}</span>
              </span>
              <span class="sub muted">{c.place ? `${c.category} · ${c.place}` : c.category}</span>
              {c.shout && <span class="shout sub">{c.shout}</span>}
            </span>
            <span class="date muted">{c.date}</span>
          </div>
        </li>
      ))}
      {checkins.length === 0 && <li class="empty muted">{emptyText}</li>}
    </ol>
  </section>
)}

<section class="container">
  <div class="cols">
    <div>
      <h2>Top Categories</h2>
      <ol class="list compact" role="list">
        {(stats?.topCategories ?? []).map((c) => (
          <li>
            <div class="row">
              <span class="name-row">
                {c.icon && (
                  <img class="icon" src={c.icon} alt="" width="20" height="20" loading="lazy" decoding="async" />
                )}
                <span class="name">{c.name}</span>
              </span>
              <span class="count muted">{n(c.count)}</span>
            </div>
          </li>
        ))}
        {(stats?.topCategories ?? []).length === 0 && <li class="empty muted">Nothing here yet.</li>}
      </ol>
    </div>
    <div>
      <h2>Top Cities</h2>
      <ol class="list compact" role="list">
        {(stats?.topCities ?? []).map((c) => (
          <li>
            <div class="row">
              <span class="name">{c.name}</span>
              <span class="count muted">{n(c.count)}</span>
            </div>
          </li>
        ))}
        {(stats?.topCities ?? []).length === 0 && <li class="empty muted">Nothing here yet.</li>}
      </ol>
    </div>
    <div>
      <h2>Top Venues</h2>
      <ol class="list compact" role="list">
        {(stats?.topVenues ?? []).map((v) => (
          <li>
            <div class="row">
              <span class="name-row">
                {v.icon && (
                  <img class="icon" src={v.icon} alt="" width="20" height="20" loading="lazy" decoding="async" />
                )}
                <span class="name">{v.name}</span>
                {v.city && <span class="city muted">{v.city}</span>}
              </span>
              <span class="count muted">{n(v.count)}</span>
            </div>
          </li>
        ))}
        {(stats?.topVenues ?? []).length === 0 && <li class="empty muted">Nothing here yet.</li>}
      </ol>
    </div>
  </div>
</section>

<style>
  .container { max-width: 44rem; }
  .head h1 { margin-bottom: 0.5rem; }

  .chart { margin-top: 1.75rem; }

  h2 { font-size: 1.1rem; margin: 2.25rem 0 0.75rem; }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 44rem;
  }
  .list li + li { border-top: 1px solid var(--surface); }
  .row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0;
  }
  .meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  /* Foursquare glyphs are dark gray on transparent: invert on the dark
     theme (the default), show as-is when the visitor picks light. */
  .icon {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    padding: 4px;
    box-sizing: border-box;
    border-radius: 50%;
    /* Fixed warm chip: the Foursquare glyphs are dark gray, so a light
       background reads correctly on both themes without filters. */
    background: #e9e4da;
  }
  :global(:root[data-theme='light']) .icon { filter: none; }

  .name {
    color: var(--heading);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub { font-size: 0.85rem; }
  .shout { font-style: italic; }

  .date,
  .count {
    margin-left: auto;
    white-space: nowrap;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  /* Two columns at the full 44rem width; the third list wraps to a second
     row, and everything stacks to one column on narrow screens. */
  .cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0 2.5rem;
    max-width: 44rem;
  }
  .compact .name { font-weight: 400; color: var(--text); }

  .city {
    font-size: 0.85rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .empty { padding: 0.55rem 0; }
</style>
